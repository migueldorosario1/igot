# ─── igot — variáveis de ambiente ──────────────────────────────────────
# Copie este arquivo para .env.local e preencha com sua chave.
#
# Pegue sua chave em: https://z.ai/
# A chave fica no servidor (API Routes) — nunca exposta no navegador.

# Chave de API do provedor padrão (Z.ai / GLM).
ZAI_API_KEY=

# (Opcional) Modelo padrão. Se vazio, usa "glm-4.6".
ZAI_MODEL=
